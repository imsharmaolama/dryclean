# Lachman Sons Drycleaners — Apache config (public/ is the document root)

# Pretty default document
DirectoryIndex index.php

# Custom error page
ErrorDocument 404 /404.php

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Long-lived caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Correct MIME type for the web app manifest
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
</IfModule>

# Never serve the env file or VCS metadata, even if misplaced
<FilesMatch "(^\.|\.env$)">
    Require all denied
</FilesMatch>
