# ---------------------------------------------------------------------------
# Lachman Sons Drycleaners — environment configuration
# Copy this file to  config/.env  and fill in real values.
# Anything left unset falls back to safe defaults (SQLite, log-only mail).
# ---------------------------------------------------------------------------

# local | production  (local shows detailed errors)
APP_ENV=production
BASE_URL=

# ---- Database -------------------------------------------------------------
# sqlite (default, zero-config) | mysql
DB_DRIVER=sqlite
# Only needed when DB_DRIVER=mysql:
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ls_drycleaners
DB_USER=root
DB_PASS=

# ---- Email notifications --------------------------------------------------
# MAIL_DRIVER: log (default, writes data/notifications.log) | mail | smtp
MAIL_DRIVER=log
MAIL_FROM_EMAIL=care@lsdrycleaners.in
MAIL_FROM_NAME="Lachman Sons Drycleaners"
# Where new pickup requests are emailed (the shop inbox):
MAIL_TO=owner@lsdrycleaners.in
# SMTP settings (only when MAIL_DRIVER=smtp). secure: tls (587) | ssl (465) | none
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=

# ---- Admin dashboard (/admin) ---------------------------------------------
ADMIN_USER=admin
# Plain password (simplest). For production prefer ADMIN_PASS_HASH below.
ADMIN_PASS=change-me-please
# Optional: bcrypt hash from  php -r "echo password_hash('your-pass', PASSWORD_DEFAULT);"
ADMIN_PASS_HASH=

# ---- Rate limiting --------------------------------------------------------
# Max form submissions per IP within the window (seconds).
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW=600
